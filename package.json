{
  "name": "promptguard-ci",
  "version": "0.1.0",
  "description": "Unit tests for your LLM prompts — catch quality, cost, and latency regressions in CI before they ship.",
  "type": "module",
  "bin": {
    "promptguard": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "demo": "tsx src/cli.ts run --config promptguard.yaml",
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "prompt",
    "eval",
    "testing",
    "ci",
    "regression",
    "openai",
    "anthropic"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RajGITTY/promptguard-cli.git"
  },
  "bugs": {
    "url": "https://github.com/RajGITTY/promptguard-cli/issues"
  },
  "homepage": "https://github.com/RajGITTY/promptguard-cli#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "openai": "^6.42.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
